# Credenciales de firma de release de la APK.
#
# 1. Copia este fichero a android/keystore.properties (SIN el .example).
# 2. Genera el keystore con el comando keytool (ver README / instrucciones).
# 3. Rellena los valores de abajo con la contrasena y el alias que elegiste.
#
# android/keystore.properties esta en .gitignore: NUNCA se sube al repo.
# Guarda una copia de rogue-release.jks y de estas contrasenas en un sitio
# seguro: si pierdes el keystore, no podras volver a actualizar la app
# instalada (Android rechaza updates firmadas con otra key).

storeFile=rogue-release.jks
storePassword=CAMBIA_ESTO
keyAlias=rogue
keyPassword=CAMBIA_ESTO
